---
import Layout from '../layouts/Layout.astro'
import { ProjectCard } from '../components/ProjectCard'
import { ProjectModal } from '../components/ProjectModal'
import { getCollection, type CollectionEntry } from 'astro:content'

const projects: CollectionEntry<'projects'>[] = await getCollection('projects')

// Get unique tags from all projects
const allTags = [...new Set(projects.flatMap((project) => project.data.tags))].sort()
---

<Layout title="Projects | Modern Developer Portfolio">
  <main class="min-h-screen py-20 px-4">
    <div class="container mx-auto max-w-6xl">
      <!-- Header -->
      <div class="text-center mb-12">
        <a href="/" class="inline-flex items-center text-blue-600 hover:text-blue-800 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd"
            ></path>
          </svg>
          Back to Home
        </a>
        <h1 class="text-4xl font-bold text-blue-900 mb-4">My Projects</h1>
        <p class="text-blue-600 max-w-2xl mx-auto">Explore my latest projects and experiments. Each project represents a unique challenge and solution.</p>
      </div>

      <!-- Search and Filter Section -->
      <div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl mb-8">
        <div class="flex flex-col gap-4">
          <!-- Search and Reset Row -->
          <div class="flex gap-4">
            <div class="flex-1">
              <input
                type="text"
                id="search"
                placeholder="Search projects..."
                class="w-full px-4 py-2 rounded-xl bg-white border border-blue-100 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition-colors"
              />
            </div>
            <button id="resetFilters" class="px-4 py-2 text-blue-600 border border-blue-100 rounded-xl hover:bg-blue-50 transition-colors"> Reset Filters </button>
          </div>

          <!-- Tags Filter -->
          <div class="flex-1">
            <p class="text-sm text-blue-600 mb-2">Filter by tags:</p>
            <div class="flex flex-wrap gap-2">
              {
                allTags.map((tag) => (
                  <label class="inline-flex items-center">
                    <input type="checkbox" value={tag} class="tag-checkbox hidden" />
                    <span class="px-3 py-1 rounded-full border border-blue-100 text-sm cursor-pointer hover:bg-blue-50 transition-colors tag-label">{tag}</span>
                  </label>
                ))
              }
            </div>
          </div>
        </div>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="projectsGrid">
        {
          projects.map((project) => (
            <div class="project-wrapper">
              <ProjectCard client:load project={project} />
            </div>
          ))
        }
      </div>
    </div>
  </main>

      </div>
    </div>
  </main>

  <!-- Project Modal -->
  <div id="project-modal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl max-w-6xl w-full max-h-[95vh] overflow-hidden">
      <div id="modal-content">
        <!-- Modal content will be populated by JavaScript -->
      </div>
    </div>
  </div>

  <!-- Image Zoom Modal -->
  <div id="image-zoom-modal" class="fixed inset-0 bg-black bg-opacity-90 hidden z-[60] flex items-center justify-center p-4">
    <div class="relative max-w-4xl max-h-full">
      <img id="zoomed-image" src="" alt="" class="max-w-full max-h-full object-contain" />
      <button id="close-zoom" class="absolute top-4 right-4 text-white text-3xl hover:text-gray-300">&times;</button>
    </div>
  </div>
</Layout>

<script>
  interface ProjectDataItem {
    element: Element
    title: string
    description: string
    tags: string[]
  }

  let projectsData: ProjectDataItem[] = []
  let currentProject: any = null
  let currentImageIndex = 0

  function openProjectModal(project: any) {
    currentProject = project
    const modal = document.getElementById('project-modal') as HTMLElement
    const content = document.getElementById('modal-content') as HTMLElement

    if (!modal || !content) return

    const images = project.data.images || [project.data.image]

    content.innerHTML = `
      <div class="flex justify-between items-center p-6 border-b border-gray-200 bg-gradient-to-r from-blue-50 to-white">
        <div>
          <h2 class="text-3xl font-bold text-gray-900">${project.data.title}</h2>
        </div>
        <button id="close-modal" class="text-gray-500 hover:text-gray-700 text-4xl leading-none h-12 w-12 flex items-center justify-center hover:bg-gray-100 rounded-full transition-colors">×</button>
      </div>

      <!-- Project description banner -->
      <div class="bg-white border-b border-gray-200 p-6">
        <div class="max-w-4xl mx-auto">
          <div class="flex items-start gap-4">
            <div class="flex-shrink-0 w-16 h-16 bg-gradient-to-br from-blue-500 to-purple-600 rounded-2xl flex items-center justify-center shadow-lg">
              <span class="text-2xl">🚀</span>
            </div>
            <div class="flex-1">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">À propos de ce projet</h3>
              <p class="text-gray-700 leading-relaxed text-lg">${project.data.description}</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row h-[calc(95vh-200px)]">
        <!-- Left side - Image carousel -->
        <div class="lg:w-1/2 p-6 border-r border-gray-200 bg-gray-50">
          <div class="sticky top-6">
            <div class="relative aspect-video bg-white rounded-2xl overflow-hidden shadow-lg cursor-pointer group" id="image-container">
              <img id="modal-image" src="${images[0]}" alt="${project.data.title}" class="w-full h-full object-cover transition-opacity duration-300" />

              ${images.length > 1 ? `
                <button id="prev-image" class="absolute left-4 top-1/2 -translate-y-1/2 bg-black bg-opacity-60 hover:bg-opacity-80 text-white p-3 rounded-full transition-all duration-200 shadow-lg opacity-0 group-hover:opacity-100">‹</button>
                <button id="next-image" class="absolute right-4 top-1/2 -translate-y-1/2 bg-black bg-opacity-60 hover:bg-opacity-80 text-white p-3 rounded-full transition-all duration-200 shadow-lg opacity-0 group-hover:opacity-100">›</button>

                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2" id="image-dots">
                  ${images.map((_, index) => `<button class="image-dot w-3 h-3 rounded-full transition-all duration-200 ${index === 0 ? 'bg-blue-600' : 'bg-gray-300 hover:bg-gray-400'}" data-index="${index}"></button>`).join('')}
                </div>

                <div class="absolute top-4 right-4 bg-black bg-opacity-60 text-white px-3 py-1 rounded-full text-sm font-medium" id="image-counter">1 / ${images.length}</div>
              ` : ''}
            </div>

            <div class="mt-6">
              <h3 class="text-xl font-semibold mb-4 text-gray-900">Technologies utilisées</h3>
              <div class="flex flex-wrap gap-2">
                ${project.data.tags.map((tag: string) => `<span class="px-4 py-2 bg-blue-50 text-blue-700 rounded-full text-sm font-medium border border-blue-200">${tag}</span>`).join('')}
              </div>
            </div>

            ${project.data.githubUrl ? `
              <div class="mt-6">
                <a href="${project.data.githubUrl}" target="_blank" rel="noopener noreferrer" class="w-full text-center px-6 py-3 bg-gray-900 text-white rounded-xl hover:bg-gray-800 transition-colors font-medium">
                  🔗 Voir le code source
                </a>
              </div>
            ` : ''}
          </div>
        </div>

        <!-- Right side - Content tabs -->
        <div class="lg:w-1/2 p-6 overflow-y-auto">
          <div class="space-y-4">
            <!-- Tabs -->
            <div class="sticky top-0 bg-white z-10 border-b border-gray-200 pb-2">
              <nav class="flex space-x-8">
                <button id="tab-description" class="tab-button active py-4 px-8 border-b-2 border-blue-500 text-blue-600 font-semibold text-xl">Description</button>
                ${project.data.ecoResponsibility ? '<button id="tab-eco" class="tab-button py-4 px-8 border-b-2 border-transparent text-gray-500 hover:text-gray-700 font-semibold text-xl">Numérique responsable</button>' : ''}
              </nav>
            </div>

            <!-- Tab content -->
            <div id="tab-content-description" class="tab-content">
              <div class="prose prose-lg max-w-none text-gray-700">
                <div class="space-y-8">
                  ${project.rendered?.html || ''}
                </div>
              </div>
            </div>

            ${project.data.ecoResponsibility ? `
              <div id="tab-content-eco" class="tab-content hidden">
                <div class="bg-green-50 border border-green-200 rounded-xl p-8">
                  <div class="flex items-center mb-6">
                    <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center mr-4">
                      🌱
                    </div>
                    <h3 class="text-2xl font-semibold text-green-800">Engagement écologique et accessibilité</h3>
                  </div>
                  <div class="eco-content-rendered">
                    ${(() => {
                      // Debug: show raw content first
                      console.log('Raw ecoResponsibility:', JSON.stringify(project.data.ecoResponsibility));

                      // Function to render markdown content properly
                      function renderMarkdown(text: string) {
                        let result = text
                          // Headers with emojis
                          .replace(/^## 🌱 Écoconception$/gm, '<h2 class="eco-section-title eco-ecoconception"><span class="eco-icon">🌱</span> Écoconception</h2>')
                          .replace(/^## ♿ Accessibilité$/gm, '<h2 class="eco-section-title eco-accessibility"><span class="eco-icon">♿</span> Accessibilité</h2>')
                          // Bold list items
                          .replace(/^- \*\*(.*?)\*\*(.*)$/gm, '<div class="eco-list-item"><span class="eco-bullet">✓</span><strong>$1</strong>$2</div>')
                          // Regular list items
                          .replace(/^- (.*?)$/gm, '<div class="eco-list-item"><span class="eco-bullet">✓</span>$1</div>')
                          // Paragraphs (lines that are not empty and not starting with - or #)
                          .replace(/^([^-\n#].*)$/gm, '<p class="eco-paragraph">$1</p>')
                          // Clean up multiple line breaks
                          .replace(/\n\n+/g, '\n')
                          // Single line breaks within paragraphs
                          .replace(/\n(?![<\/])/g, '<br>')
                          // Clean up empty paragraphs
                          .replace(/<p class="eco-paragraph"><\/p>/g, '')
                          .replace(/<p class="eco-paragraph"><br><\/p>/g, '')
                          // Trim whitespace
                          .trim();

                        console.log('Rendered result:', result);
                        return result;
                      }
                      return renderMarkdown(project.data.ecoResponsibility)
                    })()}
                  </div>
                </div>
              </div>
            ` : ''}
          </div>
        </div>
      </div>
    `

    modal.classList.remove('hidden')
    document.body.style.overflow = 'hidden'

    // Setup event listeners
    setupModalEventListeners(images)

    function setupModalEventListeners(images: string[]) {
      // Close modal
      const closeButtons = document.querySelectorAll('#close-modal, #close-modal-bottom')
      closeButtons.forEach(button => {
        button?.addEventListener('click', closeModal)
      })

      // Close on backdrop click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeModal()
        }
      })

      // Close on escape
      const handleEscape = (e: KeyboardEvent) => {
        if (e.key === 'Escape') {
          closeModal()
        }
      }
      document.addEventListener('keydown', handleEscape)

      // Image navigation
      if (images.length > 1) {
        const prevBtn = document.getElementById('prev-image')
        const nextBtn = document.getElementById('next-image')
        const imageEl = document.getElementById('modal-image') as HTMLImageElement
        const counterEl = document.getElementById('image-counter')
        const dots = document.querySelectorAll('.image-dot')

        const updateImage = (index: number) => {
          currentImageIndex = index
          imageEl.src = images[index]
          if (counterEl) counterEl.textContent = `${index + 1} / ${images.length}`
          dots.forEach((dot, i) => {
            dot.classList.toggle('bg-blue-600', i === index)
            dot.classList.toggle('bg-gray-300', i !== index)
          })
        }

        prevBtn?.addEventListener('click', (e) => {
          e.stopPropagation()
          const newIndex = currentImageIndex > 0 ? currentImageIndex - 1 : images.length - 1
          updateImage(newIndex)
        })

        nextBtn?.addEventListener('click', (e) => {
          e.stopPropagation()
          const newIndex = currentImageIndex < images.length - 1 ? currentImageIndex + 1 : 0
          updateImage(newIndex)
        })

        dots.forEach((dot, index) => {
          dot.addEventListener('click', (e) => {
            e.stopPropagation()
            updateImage(index)
          })
        })
      }

      // Image zoom
      const imageContainer = document.getElementById('image-container')
      const zoomModal = document.getElementById('image-zoom-modal') as HTMLElement
      const zoomedImage = document.getElementById('zoomed-image') as HTMLImageElement

      imageContainer?.addEventListener('click', () => {
        const imageEl = document.getElementById('modal-image') as HTMLImageElement
        if (zoomedImage && imageEl && zoomModal) {
          // Update zoom modal with current image and navigation
          updateZoomModal(currentImageIndex)
          zoomModal.classList.remove('hidden')
        }
      })

      // Close zoom
      const closeZoomBtn = document.getElementById('close-zoom')
      closeZoomBtn?.addEventListener('click', () => {
        zoomModal?.classList.add('hidden')
      })

      zoomModal?.addEventListener('click', (e) => {
        if (e.target === zoomModal) {
          zoomModal.classList.add('hidden')
        }
      })

      // Zoom modal navigation
      function updateZoomModal(imageIndex: number) {
        if (!zoomModal || !zoomedImage) return

        zoomedImage.src = images[imageIndex]

        // Update zoom navigation if multiple images
        if (images.length > 1) {
          let zoomNav = zoomModal.querySelector('.zoom-navigation')
          if (!zoomNav) {
            zoomNav = document.createElement('div')
            zoomNav.className = 'zoom-navigation absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-4'
            zoomModal.querySelector('.relative')?.appendChild(zoomNav)
          }

          zoomNav.innerHTML = `
            <button id="zoom-prev" class="bg-black bg-opacity-60 hover:bg-opacity-80 text-white p-3 rounded-full transition-all duration-200 ${imageIndex === 0 ? 'opacity-50 cursor-not-allowed' : ''}">
              ‹
            </button>
            <span class="text-white bg-black bg-opacity-60 px-3 py-1 rounded-full text-sm">${imageIndex + 1} / ${images.length}</span>
            <button id="zoom-next" class="bg-black bg-opacity-60 hover:bg-opacity-80 text-white p-3 rounded-full transition-all duration-200 ${imageIndex === images.length - 1 ? 'opacity-50 cursor-not-allowed' : ''}">
              ›
            </button>
          `

          // Add zoom navigation event listeners
          const zoomPrevBtn = document.getElementById('zoom-prev')
          const zoomNextBtn = document.getElementById('zoom-next')

          zoomPrevBtn?.addEventListener('click', (e) => {
            e.stopPropagation()
            if (imageIndex > 0) {
              updateZoomModal(imageIndex - 1)
            }
          })

          zoomNextBtn?.addEventListener('click', (e) => {
            e.stopPropagation()
            if (imageIndex < images.length - 1) {
              updateZoomModal(imageIndex + 1)
            }
          })
        }
      }

      // Tab switching
      const tabButtons = document.querySelectorAll('.tab-button')
      const tabContents = document.querySelectorAll('.tab-content')

      tabButtons.forEach(button => {
        button.addEventListener('click', () => {
          // Remove active class from all tabs
          tabButtons.forEach(btn => {
            btn.classList.remove('active', 'border-blue-500', 'text-blue-600')
            btn.classList.add('border-transparent', 'text-gray-500')
          })
          // Add active class to clicked tab
          button.classList.add('active', 'border-blue-500', 'text-blue-600')
          button.classList.remove('border-transparent', 'text-gray-500')

          // Hide all tab contents
          tabContents.forEach(content => content.classList.add('hidden'))

          // Show corresponding tab content
          const tabId = button.id.replace('tab-', 'tab-content-')
          const tabContent = document.getElementById(tabId)
          tabContent?.classList.remove('hidden')
        })
      })

      function closeModal() {
        modal.classList.add('hidden')
        document.body.style.overflow = 'unset'
        document.removeEventListener('keydown', handleEscape)
        zoomModal?.classList.add('hidden')
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search') as HTMLInputElement
    const tagCheckboxes = document.querySelectorAll('.tag-checkbox') as NodeListOf<HTMLInputElement>
    const projectsGrid = document.getElementById('projectsGrid')
    const resetButton = document.getElementById('resetFilters')

    if (!searchInput || !projectsGrid || !resetButton) return

    // Store initial projects data
    projectsData = Array.from(projectsGrid.children).map((child) => ({
      element: child,
      title: child.querySelector('h3')?.textContent?.toLowerCase() || '',
      description: child.querySelector('p')?.textContent?.toLowerCase() || '',
      tags: Array.from(child.querySelectorAll('[data-tag]')).map((tag) => tag.getAttribute('data-tag')?.toLowerCase() || ''),
    }))

    // Filter function
    const filterProjects = () => {
      const searchTerm = searchInput.value.toLowerCase()
      const selectedTags = Array.from(tagCheckboxes)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value.toLowerCase())

      projectsData.forEach((project) => {
        const matchesSearch = project.title.includes(searchTerm) || project.description.includes(searchTerm)

        const matchesTags = selectedTags.length === 0 || selectedTags.every((tag) => project.tags.includes(tag))

        const wrapper = (project.element as Element).closest('.project-wrapper')
        if (wrapper) {
          wrapper.classList.toggle('hidden', !(matchesSearch && matchesTags))
        }
      })
    }

    // Reset function
    const resetFilters = () => {
      searchInput.value = ''
      tagCheckboxes.forEach((checkbox) => {
        checkbox.checked = false
        const label = checkbox.nextElementSibling
        if (label) {
          label.classList.remove('bg-blue-500', 'text-white')
          label.classList.remove('border-blue-500')
        }
      })
      filterProjects()
    }

    // Add event listeners
    searchInput.addEventListener('input', filterProjects)
    resetButton.addEventListener('click', resetFilters)
    tagCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', (e) => {
        const label = (e.target as HTMLInputElement).nextElementSibling
        label?.classList.toggle('bg-blue-500', (e.target as HTMLInputElement).checked)
        label?.classList.toggle('text-white', (e.target as HTMLInputElement).checked)
        filterProjects()
      })
    })

    // Listen for project modal events
    window.addEventListener('openProjectModal', (event: any) => {
      openProjectModal(event.detail)
    })
  })
</script>

<!-- Project Modal -->
<div id="project-modal" class="fixed inset-0 bg-black bg-opacity-75 hidden z-50 flex items-center justify-center p-4">
  <div class="bg-white rounded-3xl shadow-xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
    <div id="modal-content">
      <!-- Modal content will be populated by JavaScript -->
    </div>
  </div>
</div>

<script>
  interface ProjectDataItem {
    element: Element
    title: string
    description: string
    tags: string[]
  }

  let projectsData: ProjectDataItem[] = []

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search') as HTMLInputElement
    const tagCheckboxes = document.querySelectorAll('.tag-checkbox') as NodeListOf<HTMLInputElement>
    const projectsGrid = document.getElementById('projectsGrid')
    const resetButton = document.getElementById('resetFilters')

    if (!searchInput || !projectsGrid || !resetButton) return

    // Store initial projects data
    projectsData = Array.from(projectsGrid.children).map((child) => ({
      element: child,
      title: child.querySelector('h3')?.textContent?.toLowerCase() || '',
      description: child.querySelector('p')?.textContent?.toLowerCase() || '',
      tags: Array.from(child.querySelectorAll('[data-tag]')).map((tag) => tag.getAttribute('data-tag')?.toLowerCase() || ''),
    }))

    // Filter function
    const filterProjects = () => {
      const searchTerm = searchInput.value.toLowerCase()
      const selectedTags = Array.from(tagCheckboxes)
        .filter((checkbox) => checkbox.checked)
        .map((checkbox) => checkbox.value.toLowerCase())

      projectsData.forEach((project) => {
        const matchesSearch = project.title.includes(searchTerm) || project.description.includes(searchTerm)

        const matchesTags = selectedTags.length === 0 || selectedTags.every((tag) => project.tags.includes(tag))

        const wrapper = (project.element as Element).closest('.project-wrapper')
        if (wrapper) {
          wrapper.classList.toggle('hidden', !(matchesSearch && matchesTags))
        }
      })
    }

    // Reset function
    const resetFilters = () => {
      searchInput.value = ''
      tagCheckboxes.forEach((checkbox) => {
        checkbox.checked = false
        const label = checkbox.nextElementSibling
        if (label) {
          label.classList.remove('bg-blue-500', 'text-white')
          label.classList.remove('border-blue-500')
        }
      })
      filterProjects()
    }

    // Add event listeners
    searchInput.addEventListener('input', filterProjects)
    resetButton.addEventListener('click', resetFilters)
    tagCheckboxes.forEach((checkbox) => {
      checkbox.addEventListener('change', (e) => {
        const label = (e.target as HTMLInputElement).nextElementSibling
        label?.classList.toggle('bg-blue-500', (e.target as HTMLInputElement).checked)
        label?.classList.toggle('text-white', (e.target as HTMLInputElement).checked)
        filterProjects()
      })
    })

    // Project modal functionality
    const modal = document.getElementById('project-modal') as HTMLElement
    const modalContent = document.getElementById('modal-content') as HTMLElement

    // Listen for project modal open events
    window.addEventListener('openProjectModal', async (event: any) => {
      const project = event.detail
      if (!modal || !modalContent || !project) return

      try {
        // Render the project content
        const rendered = await project.render()
        
        modalContent.innerHTML = `
          <div class="flex justify-between items-center p-6 border-b border-gray-200">
            <h2 class="text-2xl font-bold text-gray-900">${project.data.title}</h2>
            <button id="close-modal" class="text-gray-500 hover:text-gray-700 text-3xl leading-none">×</button>
          </div>
          <div class="overflow-y-auto max-h-[calc(90vh-80px)]">
            ${project.data.images && project.data.images.length > 0 ? `
              <div class="relative">
                <div class="aspect-video overflow-hidden">
                  <img src="${project.data.images[0]}" alt="${project.data.title}" class="w-full h-full object-cover" />
                </div>
              </div>
            ` : ''}
            <div class="p-6">
              <div class="prose max-w-none">
                ${rendered.html}
              </div>
              <div class="mt-6">
                <h3 class="text-lg font-semibold mb-3">Technologies utilisées</h3>
                <div class="flex flex-wrap gap-2">
                  ${project.data.tags.map((tag: string) => `<span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm">${tag}</span>`).join('')}
                </div>
              </div>
              ${project.data.githubUrl ? `
                <div class="mt-6">
                  <a href="${project.data.githubUrl}" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-gray-900 text-white rounded-xl hover:bg-gray-800 transition-colors inline-block">
                    Voir le code
                  </a>
                </div>
              ` : ''}
            </div>
          </div>
        `

        modal.classList.remove('hidden')

        // Setup close button
        const closeBtn = document.getElementById('close-modal')
        if (closeBtn) {
          closeBtn.addEventListener('click', () => {
            modal.classList.add('hidden')
          })
        }

        // Close on backdrop click
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.classList.add('hidden')
          }
        })

        // Close on escape
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
            modal.classList.add('hidden')
          }
        })
      } catch (error) {
        console.error('Error opening project modal:', error)
      }
    })
  })
</script>

<!-- Image Zoom Modal -->
