---
import { withBase } from '../lib/utils';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Portfolio moderne pour développeurs logiciels"
} = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-apple-gray-50 text-apple-gray-500">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --accent: rgb(0, 122, 255);
    --accent-dark: rgb(0, 64, 221);
  }

  html {
    font-family: 'SF Pro Display', 'Inter Variable', system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    padding: 0;
    min-height: 100vh;
    overscroll-behavior: none;
  }

  /* Styles Markdown - Design minimaliste et élégant */
  
  /* Titres épurés */
  .markdown-content h1,
  #about-content h1 {
    font-size: 2rem !important;
    font-weight: 700 !important;
    color: #111827 !important;
    margin: 36px 0 20px 0 !important;
    line-height: 1.3 !important;
    display: block !important;
    letter-spacing: -0.02em !important;
  }

  .markdown-content h2,
  #about-content h2 {
    font-size: 1.75rem !important;
    font-weight: 700 !important;
    color: #111827 !important;
    margin: 48px 0 24px 0 !important;
    line-height: 1.3 !important;
    display: inline-block !important;
    letter-spacing: -0.02em !important;
    position: relative !important;
    padding-bottom: 12px !important;
  }

  .markdown-content h2::after,
  #about-content h2::after {
    content: '' !important;
    position: absolute !important;
    bottom: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 3px !important;
    background: #6366f1 !important;
    border-radius: 2px !important;
  }

  .markdown-content h3,
  #about-content h3 {
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: #111827 !important;
    margin: 32px 0 16px 0 !important;
    line-height: 1.4 !important;
    display: block !important;
    padding: 12px 16px !important;
    background: #f9fafb !important;
    border-left: 4px solid #6366f1 !important;
    border-radius: 4px !important;
  }

  .markdown-content h4,
  #about-content h4 {
    font-size: 1.125rem !important;
    font-weight: 600 !important;
    color: #4b5563 !important;
    margin: 24px 0 12px 0 !important;
    line-height: 1.45 !important;
    display: block !important;
  }

  .markdown-content h5,
  #about-content h5 {
    font-size: 1rem !important;
    font-weight: 600 !important;
    color: #6b7280 !important;
    margin: 20px 0 10px 0 !important;
    line-height: 1.5 !important;
    display: block !important;
  }

  .markdown-content h6,
  #about-content h6 {
    font-size: 0.875rem !important;
    font-weight: 600 !important;
    color: #9ca3af !important;
    margin: 16px 0 8px 0 !important;
    line-height: 1.5 !important;
    display: block !important;
  }

  /* Premier titre sans margin-top */
  .markdown-content > h1:first-child,
  .markdown-content > h2:first-child,
  .markdown-content > h3:first-child,
  #about-content > h1:first-child,
  #about-content > h2:first-child,
  #about-content > h3:first-child {
    margin-top: 0 !important;
  }

  /* Paragraphes */
  .markdown-content p,
  #about-content p {
    color: #4a5568 !important;
    line-height: 1.8 !important;
    margin: 0 0 24px 0 !important;
    font-size: 1.0625rem !important;
    display: block !important;
  }

  /* Paragraphes */
  .markdown-content p,
  #about-content p {
    font-size: 1rem !important;
    line-height: 1.7 !important;
    color: #374151 !important;
    margin-bottom: 16px !important;
  }

  /* Texte en gras simple */
  .markdown-content strong,
  #about-content strong {
    color: #111827 !important;
    font-weight: 600 !important;
  }

  /* Listes minimalistes */
  .markdown-content ul,
  #about-content ul {
    margin: 16px 0 !important;
    padding-left: 0 !important;
    list-style: none !important;
  }

  .markdown-content ul li,
  #about-content ul li {
    position: relative !important;
    color: #374151 !important;
    margin-bottom: 8px !important;
    line-height: 1.6 !important;
    padding-left: 24px !important;
  }

  .markdown-content ul li::before,
  #about-content ul li::before {
    content: "•" !important;
    position: absolute !important;
    left: 8px !important;
    color: #6366f1 !important;
    font-weight: bold !important;
    font-size: 1.2em !important;
  }

  .markdown-content ol,
  #about-content ol {
    margin: 16px 0 !important;
    padding-left: 24px !important;
    list-style: decimal !important;
  }

  .markdown-content ol li,
  #about-content ol li {
    color: #374151 !important;
    margin-bottom: 8px !important;
    line-height: 1.6 !important;
    padding-left: 8px !important;
  }

  .markdown-content ol li::marker,
  #about-content ol li::marker {
    color: #6366f1 !important;
    font-weight: 600 !important;
  }

  /* Code inline subtil */
  .markdown-content code,
  #about-content code {
    background: #f3f4f6 !important;
    border: 1px solid #e5e7eb !important;
    border-radius: 4px !important;
    padding: 0.15em 0.4em !important;
    font-family: 'Menlo', 'Monaco', monospace !important;
    font-size: 0.9em !important;
    color: #ef4444 !important;
  }

  /* Blocs de code épurés */
  .markdown-content pre,
  #about-content pre {
    background: #f9fafb !important;
    border: 1px solid #e5e7eb !important;
    border-radius: 8px !important;
    padding: 16px !important;
    margin: 20px 0 !important;
    overflow: auto !important;
  }

  .markdown-content pre code,
  #about-content pre code {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    color: #1f2937 !important;
  }

  /* Liens simples */
  .markdown-content a,
  #about-content a {
    color: #6366f1 !important;
    text-decoration: none !important;
    border-bottom: 1px solid transparent !important;
    transition: border-color 0.2s ease !important;
  }

  .markdown-content a:hover,
  #about-content a:hover {
    border-bottom-color: #6366f1 !important;
  }

  /* Blockquotes épurés */
  .markdown-content blockquote,
  #about-content blockquote {
    margin: 20px 0 !important;
    padding: 12px 20px !important;
    border-left: 3px solid #6366f1 !important;
    background: #f9fafb !important;
    color: #4b5563 !important;
    font-style: italic !important;
  }

  /* Séparateurs minimalistes */
  .markdown-content hr,
  #about-content hr {
    border: none !important;
    border-top: 1px solid #e5e7eb !important;
    margin: 32px 0 !important;
  }
</style>