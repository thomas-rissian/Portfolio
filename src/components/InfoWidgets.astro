---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'

const personalData = await getCollection('personal');
const personal = personalData[0]; // Assuming there's only one personal info entry

// Get current time in different formats
const now = new Date()
const timeString = now.toLocaleTimeString('en-US', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: true,
})
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
  <!-- Location Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-red-100 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-600">
          <path
            fill-rule="evenodd"
            d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
      <div>
        <p class="text-sm text-apple-gray-400" id="info-location-label">Localisation</p>
        <p class="font-medium">{personal.data.location}</p>
      </div>
    </div>
  </div>

  <!-- Time Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-purple-100 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-purple-600">
          <path
            fill-rule="evenodd"
            d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
      <div>
        <p class="text-sm text-apple-gray-400" id="info-time-label">Heure locale</p>
        <p class="font-medium">{personal.data.timezone} • {timeString}</p>
      </div>
    </div>
  </div>

  <!-- Availability Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-green-100 rounded-full">
        <div class="w-3 h-3 bg-green-500 rounded-full"></div>
      </div>
      <div>
        <p class="text-sm text-apple-gray-400" id="info-availability-label">Disponibilité</p>
        <p class="font-medium">{personal.data.availability}</p>
      </div>
    </div>
  </div>

  <!-- Social Links Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-blue-100 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-blue-600">
          <path
            fill-rule="evenodd"
            d="M8.25 6.75a3.75 3.75 0 117.5 0 3.75 3.75 0 01-7.5 0zM15.75 9.75a3 3 0 116 0 3 3 0 01-6 0zM2.25 9.75a3 3 0 116 0 3 3 0 01-6 0zM6.31 15.117A6.745 6.745 0 0112 12a6.745 6.745 0 016.709 7.498.75.75 0 01-.372.568A12.696 12.696 0 0112 21.75c-2.305 0-4.47-.612-6.337-1.684a.75.75 0 01-.372-.568 6.745 6.745 0 011.019-4.381z"
            clip-rule="evenodd"></path>
          <path
            d="M5.082 14.254a8.287 8.287 0 00-1.308 5.135 9.687 9.687 0 01-1.764-.44l-.115-.04a.563.563 0 01-.373-.487l-.01-.121a3.75 3.75 0 013.57-4.047zM20.226 19.389a8.287 8.287 0 00-1.308-5.135 3.75 3.75 0 013.57 4.047l-.01.121a.563.563 0 01-.373.486l-.115.04c-.567.2-1.156.349-1.764.441z"
          ></path>
        </svg>
      </div>
      <div class="flex-col gap-2">
        <p class="text-sm text-apple-gray-400" id="info-social-label">Réseaux sociaux</p>
        <div class="flex gap-2 font-medium">
          {
            personal.data.socialLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-apple-gray-400 hover:text-apple-gray-500 transition-colors">
                <span class="sr-only">{link.name}</span>
                {link.icon === 'github' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                      clip-rule="evenodd"
                    />
                  </svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill-rule="evenodd"
                      d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-.79 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                      clip-rule="evenodd"
                    />
                  </svg>
                )}
                {link.icon === 'mail' && (
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { getTranslation } from '../i18n';

  // Update info widget labels
  const updateInfoLabels = async () => {
    const t = await getTranslation();
    const locationLabel = document.getElementById('info-location-label');
    const timeLabel = document.getElementById('info-time-label');
    const availabilityLabel = document.getElementById('info-availability-label');
    const socialLabel = document.getElementById('info-social-label');

    if (locationLabel) locationLabel.textContent = t.info.location;
    if (timeLabel) timeLabel.textContent = t.info.localTime;
    if (availabilityLabel) availabilityLabel.textContent = t.info.availability;
    if (socialLabel) socialLabel.textContent = t.info.socialMedia;
  };

  // Initial update
  updateInfoLabels();

  // Listen for language changes
  document.addEventListener('languageChange', updateInfoLabels);
</script>
