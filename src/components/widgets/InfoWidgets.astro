---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets'

const personalData = await getCollection('personal');
const personal = personalData.find(item => item.id === 'info' || item.slug === 'info');

// Type guard and default values
type PersonalInfo = { location: string; timezone: string; availability: string; socialLinks: any[] };
const info: PersonalInfo = personal && 'location' in personal.data 
  ? (personal.data as PersonalInfo)
  : {
      location: 'Le puy en velay',
      timezone: 'Paris',
      availability: 'En étude',
      socialLinks: []
    };

// Get current time in different formats
const now = new Date()
const timeString = now.toLocaleTimeString('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
  hour12: false,
})
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-4">
  <!-- Location Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-red-100 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-red-600">
          <path
            fill-rule="evenodd"
            d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
      <div>
        <p class="text-sm text-blue-600" id="info-location-label">Localisation</p>
        <p class="font-medium">{info.location}</p>
      </div>
    </div>
  </div>

  <!-- Time Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-purple-100 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-purple-600">
          <path
            fill-rule="evenodd"
            d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
      <div>
        <p class="text-sm text-apple-gray-400" id="info-time-label">Heure locale</p>
        <p class="font-medium" id="current-time">{info.timezone} • {timeString}</p>
      </div>
    </div>
  </div>

  <!-- Availability Widget -->
  <div class="bg-white/80 backdrop-blur-lg rounded-2xl p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 flex items-center justify-center bg-green-100 rounded-full">
        <div class="w-3 h-3 bg-green-500 rounded-full"></div>
      </div>
      <div>
        <p class="text-sm text-apple-gray-400" id="info-availability-label">Disponibilité</p>
        <p class="font-medium">{info.availability}</p>
      </div>
    </div>
  </div>

</div>

<script>
  // Update time in real-time
  const updateTime = () => {
    const timeElement = document.getElementById('current-time');
    if (timeElement) {
      const now = new Date();
      const timeString = now.toLocaleTimeString('fr-FR', {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
        hour12: false,
      });
      // Extract timezone from the existing content
      const currentText = timeElement.textContent || '';
      const timezone = currentText.split(' • ')[0] || 'Paris';
      timeElement.textContent = `${timezone} • ${timeString}`;
    }
  };

  // Initial update and interval
  updateTime();
  setInterval(updateTime, 1000);
</script>
