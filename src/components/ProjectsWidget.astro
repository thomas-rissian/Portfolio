---
// Projects widget component with i18n support
---

<div id="projects-widgets-root"></div>

<script>
  import { createElement } from 'react';
  import { createRoot } from 'react-dom/client';
  import { getTranslation, getCurrentLanguage } from '../i18n';
  import { useState, useEffect } from 'react';

  function ProjectsWidgetReact() {
    const [language, setLanguage] = useState(getCurrentLanguage());

    useEffect(() => {
      const handleLanguageChange = (event: any) => {
        setLanguage(event.detail);
      };
      document.addEventListener('languageChange', handleLanguageChange);
      return () => document.removeEventListener('languageChange', handleLanguageChange);
    }, []);

    const t = getTranslation(language);

    // Mock data - in a real implementation, this would come from Astro content collections
    const featuredProjects = [
      {
        data: {
          title: "Portfolio Personnel",
          description: "Un portfolio moderne développé avec Astro et React",
          image: "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&h=300&auto=format&fit=crop&q=80",
          demoUrl: "#",
          tags: ["Astro", "React", "TypeScript", "Tailwind"]
        }
      },
      {
        data: {
          title: "Application de Gestion de Tâches",
          description: "Application web pour la gestion de projets et de tâches avec interface moderne",
          image: "https://images.unsplash.com/photo-1611224923853-80b023f02d71?w=400&h=300&auto=format&fit=crop&q=80",
          demoUrl: "#",
          tags: ["React", "Node.js", "MongoDB", "Express"]
        }
      }
    ];

    return createElement('div', { className: 'bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl' },
      createElement('div', { className: 'md:flex justify-between items-center mb-6' },
        createElement('h3', { className: 'text-2xl font-semibold text-blue-900' }, t.projects.featuredProjects),
        createElement('a', { href: '/projects', className: 'text-blue-600 hover:text-blue-800 transition-colors text-sm' }, t.projects.viewAllProjects)
      ),
      createElement('div', { className: 'grid gap-6' },
        featuredProjects.map((project, index) =>
          createElement('a', {
            key: index,
            href: project.data.demoUrl,
            className: 'block bg-gradient-to-br from-blue-50 to-white p-4 sm:p-6 rounded-2xl hover:shadow-lg transition-all duration-300'
          },
            createElement('div', { className: 'flex flex-col sm:flex-row gap-4 sm:gap-6' },
              createElement('img', {
                src: project.data.image,
                alt: project.data.title,
                className: 'w-full sm:w-24 h-48 sm:h-24 rounded-xl object-cover'
              }),
              createElement('div', { className: 'flex-1' },
                createElement('h4', { className: 'text-xl font-medium text-blue-900 mb-2' }, project.data.title),
                createElement('p', { className: 'text-blue-600 mb-3' }, project.data.description),
                createElement('div', { className: 'flex flex-wrap gap-2' },
                  project.data.tags.map((tech, i) =>
                    createElement('span', { key: i, className: 'px-3 py-1 bg-blue-100 text-blue-600 rounded-full text-sm' }, tech)
                  )
                )
              )
            )
          )
        )
      )
    );
  }

  const container = document.getElementById('projects-widgets-root');
  if (container) {
    const root = createRoot(container);
    root.render(createElement(ProjectsWidgetReact));
  }
</script>
