---
import { getCollection, type CollectionEntry } from 'astro:content';

const testimonials: CollectionEntry<'testimonials'>[] = await getCollection('testimonials');
---

<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
  <h3 class="text-2xl font-semibold text-blue-900 mb-6">What People Say</h3>
  <div class="grid md:grid-cols-2 gap-6">
    {testimonials.map((testimonial) => (
      <div class="bg-gradient-to-br from-blue-50 to-white p-6 rounded-2xl">
        <div class="flex gap-4 items-start">
          <img 
            src={testimonial.data.avatar} 
            alt={testimonial.data.author}
            class="w-12 h-12 rounded-full object-cover"
          />
          <div class="flex-1">
            <p class="text-blue-600/90 mb-4">{testimonial.data.content}</p>
            <div>
              <p class="font-medium text-blue-900">{testimonial.data.author}</p>
              <p class="text-sm text-blue-600">
                {testimonial.data.role} at {testimonial.data.company}
              </p>
            </div>
          </div>
        </div>
      </div>
    ))}
  </div>
</div>
