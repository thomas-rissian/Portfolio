---
import Scene3D from './Scene3D';
import { personal } from '../data/personal';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 z-0">
    <Scene3D client:load />
  </div>

  <div class="container mx-auto px-4 z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex flex-col items-center mb-8 animate-fade-in">
        <div class="w-32 h-32 rounded-full border-4 border-white/50 shadow-xl mb-6 overflow-hidden bg-gradient-to-br from-blue-100 to-blue-50">
          <img
            src={personal.avatar}
            alt="Profile"
            class="w-full h-full object-cover"
          />
        </div>
        <h1 class="text-6xl font-bold mb-2">{personal.name}</h1>
        <h2 class="text-3xl text-apple-gray-400 mb-6">{personal.title}</h2>
      </div>
      <p class="text-xl text-apple-gray-500 mb-8 animate-slide-up">
        {personal.description}
      </p>
      <div class="flex flex-wrap gap-4 justify-center animate-slide-up" style="animation-delay: 200ms;">
        <a href="/projects" class="bg-apple-gray-500 text-white px-6 py-3 rounded-full hover:bg-apple-gray-400 transition-colors">
          Mes projets
        </a>
        <a href="#contact" class="border border-apple-gray-500 px-6 py-3 rounded-full hover:bg-apple-gray-100 transition-colors">
          Me contacter
        </a>
        
        <!-- CV Dropdown -->
        <div class="relative cv-dropdown">
          <button id="cv-button" class="bg-green-600 text-white px-6 py-3 rounded-full hover:bg-green-700 transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
            Mon CV
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
            </svg>
          </button>
          <div id="cv-menu" class="hidden absolute top-full mt-2 bg-white rounded-xl shadow-xl overflow-hidden z-50 min-w-[200px]">
            <a href="/cv.pdf" target="_blank" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-100 transition-colors text-gray-700">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              Voir mon CV
            </a>
            <a href="/cv.pdf" download class="flex items-center gap-3 px-4 py-3 hover:bg-gray-100 transition-colors text-gray-700 border-t">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Télécharger
            </a>
          </div>
        </div>
        
        <a href={personal.githubUrl} target="_blank" class="bg-blue-600 text-white px-6 py-3 rounded-full hover:bg-blue-700 transition-colors">
          ⭐ GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // CV Dropdown functionality
  const cvButton = document.getElementById('cv-button');
  const cvMenu = document.getElementById('cv-menu');

  if (cvButton && cvMenu) {
    // Toggle menu on button click
    cvButton.addEventListener('click', (e) => {
      e.stopPropagation();
      cvMenu.classList.toggle('hidden');
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (!cvMenu.classList.contains('hidden')) {
        cvMenu.classList.add('hidden');
      }
    });

    // Prevent menu from closing when clicking inside it
    cvMenu.addEventListener('click', (e) => {
      e.stopPropagation();
    });
  }
</script>
