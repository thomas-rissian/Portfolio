---
// Experience widget component with i18n support
import { getCollection } from 'astro:content';
import { getCurrentLanguage, getTranslation } from '../i18n';
import type { Translation } from '../i18n';

const language = getCurrentLanguage();
const translations = await getTranslation(language);

// Load experiences and education from content collections
const experiencesData = await getCollection('experiences');
const educationData = await getCollection('education');
---

<!-- Work Experience Section -->
<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl mb-8">
  <h3 class="text-2xl font-semibold mb-6" id="work-experience-title">{translations.experience.workExperience}</h3>
  <div class="space-y-6">
    {experiencesData.map((exp) => (
      <div class="border-l-2 border-blue-500 pl-4 pb-6">
        <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
          <div>
            <h4 class="text-xl font-medium text-apple-gray-500">{exp.data.title}</h4>
            <p class="text-apple-gray-400">{exp.data.company}</p>
          </div>
          <span class="text-sm text-apple-gray-300 bg-apple-gray-100 px-3 py-1 rounded-full whitespace-nowrap">
            {exp.data.period}
          </span>
        </div>
        <ul class="list-disc list-inside text-apple-gray-400 mb-3 space-y-1">
          {exp.data.description.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
        <div class="flex flex-wrap gap-2">
          {exp.data.technologies.map((tech) => (
            <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-sm">{tech}</span>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>

<!-- Education Section -->
<div class="bg-white/80 backdrop-blur-lg rounded-3xl p-6 shadow-xl">
  <h3 class="text-2xl font-semibold mb-6" id="education-title">{translations.experience.education}</h3>
  <div class="space-y-6">
    {educationData.map((edu) => (
      <div class="border-l-2 border-blue-500 pl-4 pb-6">
        <div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-4">
          <div>
            <h4 class="text-xl font-medium text-apple-gray-500">{edu.data.degree}</h4>
            <p class="text-apple-gray-400">{edu.data.school}</p>
          </div>
          <span class="text-sm text-apple-gray-300 bg-apple-gray-100 px-3 py-1 rounded-full whitespace-nowrap">
            {edu.data.period}
          </span>
        </div>
        <ul class="list-disc list-inside text-apple-gray-400 space-y-1">
          {edu.data.achievements.map((achievement) => (
            <li>{achievement}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</div>

<script>
  import { getTranslation, getCurrentLanguage } from '../i18n';

  // Update experience widget labels
  const updateExperienceLabels = async () => {
    const lang = getCurrentLanguage();
    const t = await getTranslation(lang);
    const workTitle = document.getElementById('work-experience-title');
    const educationTitle = document.getElementById('education-title');

    if (workTitle) workTitle.textContent = t.experience.workExperience;
    if (educationTitle) educationTitle.textContent = t.experience.education;
  };

  // Initial update
  updateExperienceLabels();

  // Listen for language changes
  document.addEventListener('languageChange', updateExperienceLabels);
</script>