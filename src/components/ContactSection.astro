---
import { getCurrentLanguage, getTranslation } from '../i18n';
import { getCollection } from 'astro:content';

const language = getCurrentLanguage();
const t = getTranslation(language);

const personalData = await getCollection('personal');
const personal = personalData[0];
---

<section id="contact" class="bg-white/80 backdrop-blur-lg rounded-3xl p-8 shadow-xl">
  <h3 class="text-2xl font-semibold mb-8 text-center">{t.contact.getInTouch}</h3>
  
  <div class="max-w-2xl mx-auto">
    <p class="text-center text-apple-gray-400 mb-8">
      N'hésitez pas à me contacter pour discuter de projets, d'opportunités ou simplement pour échanger !
    </p>
    
    <div class="space-y-4">
      <!-- Email -->
      <a 
        href="mailto:thomas.rissian@proton.me"
        class="flex items-center gap-4 bg-gradient-to-r from-blue-50 to-blue-100 hover:from-blue-100 hover:to-blue-200 rounded-2xl p-6 transition-all duration-300 hover:shadow-lg group"
      >
        <div class="w-14 h-14 flex items-center justify-center bg-blue-600 rounded-xl group-hover:scale-110 transition-transform">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-white">
            <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
            <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-sm text-apple-gray-400 mb-1">Email</p>
          <p class="text-lg font-medium text-apple-gray-500 group-hover:text-blue-600 transition-colors">
            thomas.rissian@proton.me
          </p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-600 group-hover:translate-x-1 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <!-- GitHub -->
      <a 
        href="https://github.com/thomas-rissian"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-gradient-to-r from-gray-50 to-gray-100 hover:from-gray-100 hover:to-gray-200 rounded-2xl p-6 transition-all duration-300 hover:shadow-lg group"
      >
        <div class="w-14 h-14 flex items-center justify-center bg-gray-800 rounded-xl group-hover:scale-110 transition-transform">
          <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-sm text-apple-gray-400 mb-1">GitHub</p>
          <p class="text-lg font-medium text-apple-gray-500 group-hover:text-gray-800 transition-colors">
            github.com/thomas-rissian
          </p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-gray-800 group-hover:translate-x-1 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <!-- LinkedIn -->
      <a 
        href="https://linkedin.com"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 bg-gradient-to-r from-blue-50 to-indigo-100 hover:from-blue-100 hover:to-indigo-200 rounded-2xl p-6 transition-all duration-300 hover:shadow-lg group"
      >
        <div class="w-14 h-14 flex items-center justify-center bg-blue-700 rounded-xl group-hover:scale-110 transition-transform">
          <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-sm text-apple-gray-400 mb-1">LinkedIn</p>
          <p class="text-lg font-medium text-apple-gray-500 group-hover:text-blue-700 transition-colors">
            Mon profil LinkedIn
          </p>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 text-blue-700 group-hover:translate-x-1 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>

      <!-- Localisation -->
      <div class="flex items-center gap-4 bg-gradient-to-r from-green-50 to-emerald-100 rounded-2xl p-6">
        <div class="w-14 h-14 flex items-center justify-center bg-green-600 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-7 h-7 text-white">
            <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="flex-1">
          <p class="text-sm text-apple-gray-400 mb-1">Localisation</p>
          <p class="text-lg font-medium text-apple-gray-500">
            {personal.data.location}, France
          </p>
        </div>
      </div>
    </div>
  </div>
</section>